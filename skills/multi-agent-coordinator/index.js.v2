/**
 * index.js - Multi-Agent Coordinator 技能主入口
 * 处理用户指令，调用 CLI 工具控制扫描器
 * 
 * 集成：任务状态控制模块 (SQLite)
 * - 任务创建时写入数据库
 * - 状态变更时更新数据库
 * - 异步子 Agent 更新状态
 */

const { execSync, spawn } = require('child_process');
const fs = require('fs');
const path = require('path');

const SKILL_DIR = __dirname;
const CONFIG_DIR = path.join(SKILL_DIR, '..', '..', 'config');
const PID_FILE = path.join(CONFIG_DIR, 'coordinator.pid');
const STATUS_FILE = path.join(CONFIG_DIR, 'coordinator.status');
const DB_PATH = path.join(CONFIG_DIR, 'task_states.db');

// 待确认的任务计划存储（使用文件持久化）
const PENDING_PLANS_FILE = path.join(CONFIG_DIR, 'pending-plans.json');

/**
 * 调用 Python 任务状态控制器
 */
function callTaskController(action, params) {
  const pythonScript = `
import sys
sys.path.insert(0, '${path.join(SKILL_DIR, 'src').replace(/\\/g, '/')}')
from task_state_controller import TaskStateController, TaskStatus

ctrl = TaskStateController('${DB_PATH.replace(/\\/g, '/')}')

if '${action}' == 'create':
    result = ctrl.create_task(**${JSON.stringify(params)})
    print('SUCCESS' if result else 'FAILED')
    
elif '${action}' == 'update':
    status = TaskStatus('${params.status}')
    result = ctrl.update_status(
        '${params.task_id}',
        status,
        '${params.changed_by || 'system'}',
        '${params.reason || ''}',
        ${params.error_msg ? `'${params.error_msg}'` : 'None'}
    )
    print('SUCCESS' if result else 'FAILED')
    
elif '${action}' == 'get':
    task = ctrl.get_task('${params.task_id}')
    import json
    print(json.dumps(task, default=str))
    
elif '${action}' == 'list_active':
    tasks = ctrl.list_active_tasks()
    import json
    print(json.dumps(tasks, default=str))
`;
  
  try {
    const tempScript = path.join(CONFIG_DIR, 'temp_ctrl.py');
    fs.writeFileSync(tempScript, pythonScript, 'utf-8');
    
    const result = execSync(`python "${tempScript}"`, {
      encoding: 'utf-8',
      timeout: 5000
    });
    
    fs.unlinkSync(tempScript);
    
    // 尝试解析 JSON
    try {
      return JSON.parse(result.trim());
    } catch {
      return result.trim();
    }
  } catch (e) {
    console.error('[错误] 调用状态控制器失败:', e.message);
    return null;
  }
}

/**
 * 保存待确认计划到文件
 */
function savePendingPlan(plan) {
  try {
    const plans = loadPendingPlans();
    plans[plan.id] = plan;
    fs.writeFileSync(PENDING_PLANS_FILE, JSON.stringify(plans, null, 2), 'utf-8');
    return true;
  } catch (e) {
    console.error(`[错误] 保存计划失败: ${e.message}`);
    return false;
  }
}

/**
 * 加载待确认计划
 */
function loadPendingPlans() {
  try {
    if (fs.existsSync(PENDING_PLANS_FILE)) {
      return JSON.parse(fs.readFileSync(PENDING_PLANS_FILE, 'utf-8'));
    }
  } catch (e) {
    console.error(`[错误] 加载计划失败: ${e.message}`);
  }
  return {};
}

/**
 * 获取并移除待确认计划
 */
function getAndRemovePendingPlan() {
  const plans = loadPendingPlans();
  const planIds = Object.keys(plans);
  if (planIds.length === 0) return null;
  
  const planId = planIds[0];
  const plan = plans[planId];
  delete plans[planId];
  
  try {
    fs.writeFileSync(PENDING_PLANS_FILE, JSON.stringify(plans, null, 2), 'utf-8');
  } catch (e) {
    console.error(`[错误] 更新计划文件失败: ${e.message}`);
  }
  
  return { planId, plan };
}

/**
 * 清空待确认计划
 */
function clearPendingPlans() {
  try {
    if (fs.existsSync(PENDING_PLANS_FILE)) {
      fs.unlinkSync(PENDING_PLANS_FILE);
    }
    return true;
  } catch (e) {
    console.error(`[错误] 清空计划失败: ${e.message}`);
    return false;
  }
}

/**
 * 生成任务执行计划
 * @param {string} userRequest - 用户的原始需求
 * @returns {Object} 任务计划
 */
function generateTaskPlan(userRequest) {
  // 分析需求类型
  const request = userRequest.toLowerCase();
  
  // 账单分析任务
  if (request.includes('账单') || request.includes('billing')) {
    return {
      id: `plan-${Date.now()}`,
      title: '账单分析报告生成',
      description: userRequest,
      steps: [
        { step: 1, action: '复制账单文件到共享目录', node: '主节点 (kimi)', status: 'pending' },
        { step: 2, action: '预建输出目录结构', node: '主节点 (kimi)', status: 'pending' },
        { step: 3, action: '发送分析任务给 Claude Code', node: '主节点 (kimi)', status: 'pending' },
        { step: 4, action: '读取账单数据并分析', node: '子节点 (claude)', status: 'pending' },
        { step: 5, action: '生成 Markdown 报告', node: '子节点 (claude)', status: 'pending' },
        { step: 6, action: '读取报告并展示给用户', node: '主节点 (kimi)', status: 'pending' }
      ],
      estimatedTime: '2-3 分钟',
      involvedNodes: ['kimi (主)', 'claude (子)'],
      resources: {
        inputFiles: ['billing_*.csv'],
        outputDir: 'D:\\projects\\workspace\\shared\\output\\'
      }
    };
  }
  
  // 代码开发任务
  if (request.includes('代码') || request.includes('开发') || request.includes('编写')) {
    return {
      id: `plan-${Date.now()}`,
      title: '代码开发任务',
      description: userRequest,
      steps: [
        { step: 1, action: '分析需求并设计架构', node: '主节点 (kimi)', status: 'pending' },
        { step: 2, action: '预建项目目录结构', node: '主节点 (kimi)', status: 'pending' },
        { step: 3, action: '分配编码任务给子节点', node: '主节点 (kimi)', status: 'pending' },
        { step: 4, action: '编写核心代码', node: '子节点 (claude)', status: 'pending' },
        { step: 5, action: '代码审查和测试', node: '主节点 (kimi)', status: 'pending' }
      ],
      estimatedTime: '5-10 分钟',
      involvedNodes: ['kimi (主)', 'claude (子)'],
      resources: {
        outputDir: 'D:\\projects\\workspace\\shared\\output\\'
      }
    };
  }
  
  // 通用任务模板
  return {
    id: `plan-${Date.now()}`,
    title: '多节点协作任务',
    description: userRequest,
    steps: [
      { step: 1, action: '分析需求并制定计划', node: '主节点 (kimi)', status: 'pending' },
      { step: 2, action: '预建必要的目录结构', node: '主节点 (kimi)', status: 'pending' },
      { step: 3, action: '发送任务给子节点执行', node: '主节点 (kimi)', status: 'pending' },
      { step: 4, action: '执行任务', node: '子节点', status: 'pending' },
      { step: 5, action: '汇总结果并展示', node: '主节点 (kimi)', status: 'pending' }
    ],
    estimatedTime: '3-5 分钟',
    involvedNodes: ['kimi (主)', 'claude (子)'],
    resources: {
      outputDir: 'D:\\projects\\workspace\\shared\\output\\'
    }
  };
}

/**
 * 格式化任务计划为可读文本
 */
function formatTaskPlan(plan) {
  let output = `\n========================================\n`;
  output += `📋 任务执行计划\n`;
  output += `========================================\n\n`;
  output += `任务: ${plan.title}\n`;
  output += `描述: ${plan.description}\n\n`;
  
  output += `执行步骤:\n`;
  plan.steps.forEach(s => {
    output += `  ${s.step}. [${s.node}] ${s.action}\n`;
  });
  
  output += `\n预计耗时: ${plan.estimatedTime}\n`;
  output += `涉及节点: ${plan.involvedNodes.join(', ')}\n`;
  
  if (plan.resources.inputFiles) {
    output += `输入文件: ${plan.resources.inputFiles.join(', ')}\n`;
  }
  output += `输出目录: ${plan.resources.outputDir}\n`;
  
  output += `\n========================================\n`;
  output += `请回复 "确认" 开始执行，或回复 "取消" 放弃\n`;
  output += `========================================\n`;
  
  return output;
}

